{
  "name": "vue-auto-import-checker",
  "version": "1.2.0",
  "description": "Check if the used tags are all registered within your components.d.ts",
  "type": "module",
  "types": "./types/**/*.ts",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "test": "vitest run --reporter=tree",
    "test:watch": "vitest --reporter=tree",
    "lint": "oxlint --tsconfig=tsconfig.json",
    "tsc": "tsc --noEmit",
    "build": "tsc --build"
  },
  "engines": {
    "node": ">=20.19.1",
    "npm": ">=10.8.2"
  },
  "bin": {
    "vue-auto-import-checker": "cli.js"
  },
  "keywords": [
    "vue",
    "vuetify",
    "vuuse",
    "quasar",
    "nuxt",
    "naive-ui",
    "primevue",
    "vue-router",
    "unplugin",
    "components.d.ts",
    "tags"
  ],
  "author": "Marcel Wagner (https://github.com/marcelwagner)",
  "contributors": [
    {
      "name": "Chi Nguyen",
      "url": "https://github.com/cnguyen-de"
    },
    {
      "name": "Marcus Moedinger",
      "url": "https://github.com/mreise"
    }
  ],
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/vue-auto-import-checker",
  "bugs": {
    "url": "https://github.com/marcelwagner/vue-auto-import-checker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelwagner/vue-auto-import-checker.git"
  },
  "devDependencies": {
    "@types/node": "^20.19.1",
    "@vueuse/components": "^14.2.1",
    "naive-ui": "^2.44.1",
    "nuxt": "^4.4.2",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.61.0",
    "primevue": "^4.5.5",
    "quasar": "^2.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "vuetify": "^4.0.5"
  },
  "dependencies": {
    "commander": "14.0.3",
    "html-tags": "5.1.0",
    "svg-tag-names": "3.0.1"
  }
}
